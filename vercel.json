{
  "buildCommand": "pip3 install -e '.[all]' && npm --prefix web run build",
  "outputDirectory": "web/.next",
  "framework": "nextjs",
  "installCommand": "npm --prefix web install",
  "env": {
    "NEXT_PUBLIC_DEMO_MODE": "true",
    "NEXT_TELEMETRY_DISABLED": "1"
  },
  "build": {
    "env": {
      "NEXT_PUBLIC_DEMO_MODE": "true",
      "NEXT_TELEMETRY_DISABLED": "1"
    }
  }
}
